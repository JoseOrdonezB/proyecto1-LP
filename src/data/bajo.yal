let digit = ['0'-'9']
let letter = ['a'-'z''A'-'Z']
let ws = [' ''\t''\n']+

rule tokens =
    ws              { return WHITESPACE }
  | letter+         { return ID }
  | digit+          { return NUMBER }
  | '='             { return IGUAL }
  | '+'             { return SUMA }
  | '-'             { return RESTA }